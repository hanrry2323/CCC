        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://192.168.3.116:7777 http://127.0.0.1:7777 ws://192.168.3.116:7777 ws://127.0.0.1:7777; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://192.168.3.116:* http://127.0.0.1:*"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "CCC Desktop",
        "width": 1200
      }
    ]
