{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "http://127.0.0.1:8084",
    "distDir": "http://127.0.0.1:8084",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "CCC Cockpit",
    "version": "0.29.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": false,
        "open": true,
        "save": true,
        "message": true
      },
      "path": {
        "all": true
      },
      "process": {
        "all": false,
        "exit": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.ccc.cockpit",
      "longDescription": "CCC Cockpit — 用 Tauri 包装的 CCC Chat Server 桌面应用",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "minimumSystemVersion": "12.0",
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "CCC Cockpit 桌面端",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8084 ws://127.0.0.1:8084 ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://127.0.0.1:* https://asset.localhost; font-src 'self' data:; media-src 'self' asset: http://asset.localhost"
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "CCC Cockpit"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "minHeight": 600,
        "minWidth": 800,
        "resizable": true,
        "title": "CCC Cockpit",
        "width": 1200,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ]
  }
}