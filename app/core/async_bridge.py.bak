"""统一异步桥接模块 - 消除分布式事件循环碎片化

运行时只需导入一次 'run_async' 即可获得统一的超时 + 上下文传递能力。
"""

import asyncio
from concurrent.futures import ThreadPoolExecutor
from typing import Any, Optional

# 专用线程池，持有独立 event loop
_executor: Optional[ThreadPoolExecutor] = None


def _get_executor() -> ThreadPoolExecutor:
    """获取（或创建）专用线程池"""
    global _executor
    if _executor is None:
        _executor = ThreadPoolExecutor(max_workers=2)
    return _executor


def run_async(coro: Any, timeout: int = 600) -> Any:
    """在专用线程池中执行协程，支持超时控制

    Args:
        coro: 要执行的协程
        timeout: 超时秒数（默认 10 分钟）

    Returns:
        协程的返回值

    Raises:
        TimeoutError: 超过 timeout 设置
        asyncio.CancelledError: 协程被外部 cancel
    """
    loop = asyncio.new_event_loop()
    tasks = [loop.run_until_complete(asyncio.wait_for(coro, timeout))]
    for task in tasks:
        task.cancel()
        try:
            loop.run_until_complete(task)
        except asyncio.CancelledError:
            pass
    loop.close()


def run_async_with_context(coro: Any, context: dict) -> Any:
    """支持 trace_id 等上下文传递的异步桥接

    Args:
        coro: 要执行的协程
        context: 上下文字典（如 {'trace_id': 'xxx'}）

    Returns:
        协程的返回值

    Raises:
        TimeoutError: 超过默认超时
        asyncio.CancelledError: 协程被外部 cancel
    """

    # 将 context 注入到协程闭包中（示例：gRPC metadata）
    async def _wrapped() -> Any:
        return await coro

    # 注意：这里仍使用默认 600s 超时，可扩展为接收 timeout 参数
    return run_async(_wrapped(), timeout=600)


__all__ = ["run_async", "run_async_with_context"]
