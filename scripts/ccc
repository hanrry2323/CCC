#!/bin/bash
set -euo pipefail

REAL_SCRIPT="$(realpath "$0")"
CCC_HOME="$(cd "$(dirname "$REAL_SCRIPT")/.." && pwd)"
SCRIPT_NAME="$(basename "$0")"

# cccq alias: cccq [args] = ccc status [args] (向后兼容)
if [ "$SCRIPT_NAME" = "cccq" ]; then
    if [ "${1:-}" = "-w" ] || [ "${1:-}" = "--watch" ]; then
        set -- status -w
    elif [ -z "${1:-}" ] || [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        set -- help
    elif [ "${1:-}" != "status" ] && [ "${1:-}" != "search" ] && [ "${1:-}" != "init" ] && [ "${1:-}" != "diff" ]; then
        set -- status "$@"
    fi
fi

case "${1:-help}" in
  status)
    shift
    # -w/--watch: 每 10 秒自动刷新
    WATCH_MODE=0
    if [[ "${1:-}" == "-w" || "${1:-}" == "--watch" ]]; then
        WATCH_MODE=1
    fi
    while true; do
        [[ "$WATCH_MODE" == "1" ]] && clear
        echo "=== 后台 Claude 进程 ==="
        ps -eo pid,etime,pcpu,rss,command | grep -E "claude$|claude -p" | grep -v "grep\|cccq\|bash -c" | head -5 | awk '{printf "  PID %s  跑了 %s  CPU %s%%  RAM %sMB\n", $1, $2, $3, int($4/1024)}'
        echo ""
        echo "=== 最近 CCC 任务 (本项目) ==="
        for f in $(ls -t .ccc/phases/*.phases.json 2>/dev/null | head -3); do
          python3 - "$f" <<'PYEOF'
import json, os, sys
fp = sys.argv[1]
try:
    d = json.load(open(fp))
    ps = d.get('phases') or []
    name = os.path.basename(fp).replace('.phases.json','')
    if not ps: sys.exit()
    done = sum(1 for p in ps if p.get('status') in ('done','verified','skipped'))
    plan = '.ccc/plans/' + name + '.plan.md'
    goal = ''
    if os.path.exists(plan):
        for line in open(plan):
            if line.startswith('| **目标**'):
                parts = [p.strip() for p in line.split('|')]
                if len(parts) >= 3: goal = parts[2]; break
    print(f'  [{done}/{len(ps)}] {name}')
    if goal: print(f'    目标: {goal[:80]}')
    for p in ps:
        st = (p.get('status') or '?')
        sym = {'pending':'○ 等','in_progress':'◐ 跑','verifying':'◑ 验','verified':'✓','done':'✓','failed':'✗'}.get(st,'?')
        title = (p.get('title') or '')[:60]
        print(f'    {sym} phase {p.get("id","?")}: {title}')
except: pass
PYEOF
        done
        echo ""
        echo "=== 最近 3 个 git commit ==="
        git log --oneline -3 2>/dev/null | sed 's/^/  /'
        [[ "$WATCH_MODE" == "1" ]] && sleep 10 || break
    done
    ;;
  search)
    shift
    exec python3 "$CCC_HOME/scripts/ccc-search.py" "$@"
    ;;
  init)
    shift
    exec python3 "$CCC_HOME/scripts/ccc-init.py" "$@"
    ;;
  diff)
    shift
    if git -C . rev-parse --git-dir >/dev/null 2>&1; then
      echo "=== Working Tree ($(git -C . rev-parse --show-toplevel)) ==="
      git -C . status --short | head -20
      echo ""
      echo "=== Diff stat ==="
      git -C . diff --stat | head -20
    else
      echo "(当前目录不在 git 仓库里)"
    fi
    ;;
  help|--help|-h|"")
    cat <<'EOF'
ccc — CCC Framework CLI

Usage: ccc <command> [options]

Commands:
  status           Task status (background Claude + CCC task progress + Chinese description)
  search <query>   Cross-project .ccc/ search for <query>
  init <name>      New project initialization (AGENTS.md + .ccc/profile.md)
  diff             Working tree concise diff
  help             Show this help

Examples:
  ccc status
  ccc search "Verdict"
  ccc init /tmp/my-project
  ccc diff
EOF
    ;;
  *)
    echo "Error: unknown command 'ccc $1'" >&2
    echo "Run 'ccc help' for available commands." >&2
    exit 1
    ;;
esac
