#!/bin/bash
set -euo pipefail

REAL_SCRIPT="$(realpath "$0")"
CCC_HOME="$(cd "$(dirname "$REAL_SCRIPT")/.." && pwd)"
SCRIPT_NAME="$(basename "$0")"

# cccq alias: cccq [args] = ccc status [args] (向后兼容)
if [ "$SCRIPT_NAME" = "cccq" ]; then
    if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        set -- help
elif [ "${1:-}" != "status" ] && [ "${1:-}" != "search" ] && [ "${1:-}" != "init" ] && [ "${1:-}" != "diff" ] && [ "${1:-}" != "commit" ] && [ "${1:-}" != "run" ]; then
      set -- status "$@"
    fi
fi

case "${1:-help}" in
  status)
    shift
    # -w/--watch [N]: 每 N 秒自动刷新 (默认 10)
    WATCH_MODE=0
    INTERVAL=10
    if [[ "${1:-}" == "-w" || "${1:-}" == "--watch" ]]; then
        WATCH_MODE=1
        shift
        if [[ -n "${1:-}" && ! "${1:-}" =~ ^[0-9]+$ ]]; then
            echo "Error: -w expects seconds (got '$1')" >&2
            exit 1
        fi
        if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
            INTERVAL=$1
            shift
        fi
    fi
    if ! [[ "$INTERVAL" =~ ^[0-9]+$ ]] || (( INTERVAL < 1 )); then
        echo "Error: -w interval must be positive integer (got: '$INTERVAL')" >&2
        exit 1
    fi
    while true; do
        [[ "$WATCH_MODE" == "1" ]] && clear 2>/dev/null || true
        echo "=== 后台 Claude 进程 ==="
        ps -eo pid,etime,pcpu,rss,command | grep -E "claude$|claude -p" | grep -v "grep\|cccq\|bash -c" | head -5 | awk '{printf "  PID %s  跑了 %s  CPU %s%%  RAM %sMB\n", $1, $2, $3, int($4/1024)}'
        echo ""
        echo "=== 最近 CCC 任务 (本项目) ==="
        for f in $(ls -t .ccc/phases/*.phases.json 2>/dev/null | head -3); do
          python3 - "$f" <<'PYEOF'
import json, os, sys
fp = sys.argv[1]
try:
    d = json.load(open(fp))
    ps = d.get('phases') or []
    name = os.path.basename(fp).replace('.phases.json','')
    if not ps: sys.exit()
    done = sum(1 for p in ps if p.get('status') in ('done','verified','skipped'))
    plan = '.ccc/plans/' + name + '.plan.md'
    goal = ''
    if os.path.exists(plan):
        for line in open(plan):
            if line.startswith('| **目标**'):
                parts = [p.strip() for p in line.split('|')]
                if len(parts) >= 3: goal = parts[2]; break
    print(f'  [{done}/{len(ps)}] {name}')
    if goal: print(f'    目标: {goal[:80]}')
    for p in ps:
        st = (p.get('status') or '?')
        sym = {'pending':'○ 等','in_progress':'◐ 跑','verifying':'◑ 验','verified':'✓','done':'✓','failed':'✗'}.get(st,'?')
        title = (p.get('title') or '')[:60]
        print(f'    {sym} phase {p.get("id","?")}: {title}')
except Exception: pass
PYEOF
        done
        echo ""
        echo "=== 最近 3 个 git commit ==="
        git log --oneline -3 2>/dev/null | sed 's/^/  /'
        [[ "$WATCH_MODE" == "1" ]] && sleep "$INTERVAL" || break
    done
    ;;
  search)
    shift
    exec python3 "$CCC_HOME/scripts/ccc-search.py" "$@"
    ;;
  init)
    shift
    exec python3 "$CCC_HOME/scripts/ccc-init.py" "$@"
    ;;
  diff)
    shift
    if git -C . rev-parse --git-dir >/dev/null 2>&1; then
      echo "=== Working Tree ($(git -C . rev-parse --show-toplevel)) ==="
      git -C . status --short | head -20
      echo ""
      echo "=== Diff stat ==="
      git -C . diff --stat | head -20
    else
      echo "(当前目录不在 git 仓库里)"
    fi
    ;;

  commit)
    shift
    if [[ $# -lt 2 ]]; then
        echo "用法: ccc commit <workspace> <task> [--phase N]" >&2
        echo "  自动 commit Executor 输出的改动（委托 ccc-exec-commit.sh）" >&2
        echo "  详见: ccc-exec-commit.sh --help" >&2
        exit 2
    fi
    exec "$CCC_HOME/scripts/ccc-exec-commit.sh" "$@"
    ;;

  run)
    shift
    if [[ $# -lt 2 ]]; then
        echo "用法: ccc run <workspace> <task> [--dry-run] [--skip-register]" >&2
        echo "  ZCode 端到端编排器（Planner→Executor→Verifier→commit→finish）" >&2
        echo "  详见: ccc-zcode-orchestrate.sh --help" >&2
        exit 2
    fi
    exec "$CCC_HOME/scripts/ccc-zcode-orchestrate.sh" "$@"
    ;;

    help|--help|-h|"")
    cat <<'EOF'
ccc — CCC Framework CLI

Usage: ccc <command> [options]

Commands:
  status [-w [N]]    Task status (background Claude + CCC task progress + Chinese description). -w [N] for watch refresh every N seconds (default 10)
  search <query>     Cross-project .ccc/ search for <query>
  init <path>        New project initialization (AGENTS.md + .ccc/profile.md)
  diff               Working tree concise diff
  commit <ws> <task> Auto-commit Executor output (delegates to ccc-exec-commit.sh)
  run <ws> <task>    ZCode end-to-end orchestrator (Planner→Executor→Verifier→commit→finish). See ccc-zcode-orchestrate.sh
  help               Show this help

Examples:
  ccc status
  ccc status -w 5
  ccc search "Verdict"
  ccc init /tmp/my-project
  ccc diff
  ccc commit . ccc-exec-commit-20260705
  ccc run . hello-ccc-demo-v2 --dry-run  # dry-run the full 6-step pipeline
EOF
    ;;
  *)
    echo "Error: unknown command 'ccc $1'" >&2
    echo "Run 'ccc help' for available commands." >&2
    exit 1
    ;;
esac
